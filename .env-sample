# Configure your environment variables in this file

# Site environment: local | development | staging | testing | production
# local     - developer's own machine (debug on, HTTP allowed, wildcard ALLOWED_HOSTS)
# development - shared dev server (debug on, HTTP allowed)
# staging   - pre-prod server (debug off, HTTPS required)
# production - live site (debug off, HTTPS required)
UL_ENVIRONMENT=production

# Allows running multiple instances of the same environment on the same machine.
UL_CONTAINER_NAME=production

# When false (default for non-local environments), the app redirects plain HTTP requests to
# HTTPS. For local/development environments this defaults to true automatically, so you only
# need to set it explicitly if you want to override that default (e.g. force HTTPS locally).
#UL_UNSAFE_ALLOW_HTTP=False
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Base URL used to build absolute links in emails/notifications (e.g. safety check-in
# reminders). Must match the public URL of this environment, including scheme - defaults to
# http://localhost:21080 if unset, which is only correct for local dev. REQUIRED for every
# deployed environment (staging/production) - a missing value here means safety-alert and
# account emails will link back to localhost instead of your real domain.
UL_SITE_URL=https://your-domain.example.com

# Comma-separated list of hostnames Django is allowed to serve (sets ALLOWED_HOSTS).
# Leave blank to use the default: urbanlens.org, localhost, 127.0.0.1
# (localhost/127.0.0.1 are required for Docker's internal /health/ curl probes.)
# Example for a custom staging domain:
#   UL_ALLOWED_HOSTS=staging.urbanlens.org,localhost,127.0.0.1
#UL_ALLOWED_HOSTS=

# Database name - must match what docker-compose passes via UL_DB_NAME.
UL_DB_NAME=UrbanLensDB

# Database password. Change this before deploying.
UL_DB_PASS=changeme-train-usage-overdrive

# Get your Mapbox API token at https://account.mapbox.com
VITE_MAPBOX_API_TOKEN=

# Get your Google Client ID at https://console.developers.google.com/
UL_GOOGLE_CLIENT_ID=

# Get your Google Client Secret at https://console.developers.google.com/
UL_GOOGLE_CLIENT_SECRET=

# Get your Smithsonian API Key at https://api.si.edu
UL_SMITHSONIAN_API_KEY=

# Get your Google Maps API Key at https://console.developers.google.com/
UL_GOOGLE_UNRESTRICTED_API_KEY=
UL_GOOGLE_DOMAIN_RESTRICTED_API_KEY=
UL_GOOGLE_PUBLIC_API_KEY=

# Configure your Google Custom Search Engine tenant at https://cse.google.com/cse/all
UL_GOOGLE_SEARCH_TENANT=

# Get your Brave Search API Key at https://api.search.brave.com/app/keys
# This is the default search provider. Sign up for a free or paid plan and create a key.
UL_BRAVE_SEARCH_API_KEY=

# Get your OpenWeatherMap API Key at https://home.openweathermap.org/users/sign_up
UL_OPENWEATHERMAP_API_KEY=

# Get your National Park Service API Key at https://www.nps.gov/subjects/digital/nps-data-api.htm
UL_NPS_API_KEY=

# REData (../REData) is the standalone service that provides county property-ownership/tax
# records - see docs/redata.md. Generate an API key in its dashboard (or via manage.py) with
# at least the "parcels:read" scope.
UL_REDATA_API_URL=
UL_REDATA_API_KEY=

# Get your Twilio credentials at https://console.twilio.com/ - used for outbound SMS/WhatsApp notifications
UL_TWILIO_ACCOUNT_SID=
UL_TWILIO_AUTH_TOKEN=
UL_TWILIO_SMS_FROM_NUMBER=
UL_TWILIO_WHATSAPP_FROM_NUMBER=

# Configure your Cloudflare AI Endpoint in your Cloudflare dashboard
UL_CLOUDFLARE_AI_ENDPOINT=

# Get your Cloudflare AI API Key at https://dash.cloudflare.com/
UL_CLOUDFLARE_AI_API_KEY=

# Configure your Cloudflare Worker AI Endpoint in your Cloudflare dashboard
UL_CLOUDFLARE_WORKER_AI_ENDPOINT=

# Get your Cloudflare Worker AI API Key at https://dash.cloudflare.com/
UL_CLOUDFLARE_WORKER_AI_API_KEY=

# Configure your Hugging Face AI Endpoint in your Hugging Face settings
UL_HUGGINGFACE_AI_ENDPOINT=

# Get your Hugging Face AI API Key at https://huggingface.co/settings/tokens
UL_HUGGINGFACE_AI_API_KEY=

# Get your OpenAI API Key at https://beta.openai.com/signup/
UL_OPENAI_API_KEY=

# Free, self-hosted local AI photo keywording via https://ollama.com/ - leave blank to disable
UL_OLLAMA_BASE_URL=
UL_OLLAMA_VISION_MODEL=llava

UL_APPLE_MAPS_API_KEY=
UL_BING_MAPS_API_KEY=

# Get your Azure Maps subscription key at https://portal.azure.com -> your Azure Maps account -> Authentication
UL_AZURE_MAPS_SUBSCRIPTION_KEY=
UL_MAPBOX_API_KEY=
UL_MAPILLARY_ACCESS_TOKEN=
UL_USGS_API_KEY=
UL_USGS_USERNAME=
UL_SEARXNG_BASE_URL=
# Optional: override the SearXNG image engines used by the "Web Images" media
# provider (comma-separated engine names as configured in your instance's
# settings.yml). Leave blank to use the built-in default engine list.
UL_SEARXNG_IMAGE_ENGINES=

# SMTP (e.g. Smtp2Go)
UL_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
UL_EMAIL_HOST=smtp.gmail.com
UL_EMAIL_PORT=587
UL_EMAIL_TLS=True
UL_EMAIL_USE_SSL=False
UL_EMAIL_FROM=noreply@mydomain.org
UL_EMAIL_USER=
UL_EMAIL_PASSWORD=
# Database backups
# Scheduled backups are checked hourly; this controls whether they run.
#UL_BACKUP_ENABLED=True
# Minimum hours between scheduled backups. Site admins can override this in the UI.
#UL_BACKUP_FREQUENCY_HOURS=24
# Number of backup files to retain. Site admins can override this in the UI.
#UL_BACKUP_RETENTION=30
# Optional backup directory override (defaults to the app backups directory).
#UL_BACKUPS_DIR=backups

# Staging tooling
# Path to the production checkout on the same Docker host, used by
# bin/clone_prod_to_staging.sh to locate prod's .env (container names, DB
# credentials) when cloning its database into staging. Only meaningful in a
# staging environment's .env - has no effect on the running application.
# Can also be passed per-invocation via --prod-dir, which takes precedence.
#UL_PROD_DIR=/srv/urbanlens-production

# Deploy webhook (staging/dev only)
# Configures bin/deploy_webhook.py (see docs/deployment.md) - a listener that
# triggers bin/deploy.sh automatically when this branch is pushed, instead of
# manually running `docker compose down && git pull && docker compose up --build`
# over ssh. Not meaningful in production, which should deploy deliberately.
# Shared secret configured on the same value as the GitHub/GitLab webhook.
#UL_DEPLOY_WEBHOOK_SECRET=
# Branch this host redeploys on push, e.g. staging or development.
#UL_DEPLOY_WEBHOOK_BRANCH=
# Bind address/port for the listener - defaults are localhost-only; see
# docs/deployment.md before exposing this beyond the host.
#UL_DEPLOY_WEBHOOK_HOST=127.0.0.1
#UL_DEPLOY_WEBHOOK_PORT=9000

# Additional env vars.
# Do not change these unless you know what you are doing.
# They are listed with their default values.
#UL_ALLOW_TEST_INTERNET=False

# When true, authenticated users WITHOUT site-admin permission can also see and use the
# developer toolbar (e.g. QA/test accounts). Only takes effect when UL_ENVIRONMENT (or the
# site admin's environment override) is local, development, or testing - ignored in
# staging/production regardless of this setting.
#UL_ALLOW_DEV_TOOLBAR_FOR_NON_ADMINS=False