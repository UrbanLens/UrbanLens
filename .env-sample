# Configure your environment variables in this file

# Site environment: development, testing, production, local, staging (can be overridden by admin environment setting)
UL_ENVIRONMENT=production

# When false (default), the app redirects plain HTTP requests to HTTPS. Set to true only for
# local development without TLS (e.g. http://localhost:21080). Production must leave this false.
UL_UNSAFE_ALLOW_HTTP=False

# Database name - must match what docker-compose passes via UL_DB_NAME.
UL_DB_NAME=UrbanLensDB

# Database password. Change this before deploying.
UL_DB_PASS=train-usage-overdrive

# Get your Mapbox API token at https://account.mapbox.com
VITE_MAPBOX_API_TOKEN=

# Get your Google Client ID at https://console.developers.google.com/
UL_GOOGLE_CLIENT_ID=

# Get your Google Client Secret at https://console.developers.google.com/
UL_GOOGLE_CLIENT_SECRET=

# Get your Smithsonian API Key at https://api.si.edu
UL_SMITHSONIAN_API_KEY=

# Get your Google Places API Key at https://console.developers.google.com/
# NOTE: This __MUST__ have no url restrictions, which means in practice that it must be a separate key from your Google Maps API Key. It also must have the Places API enabled in the Google Cloud Console. If you use the same key for both, you will likely encounter "REQUEST_DENIED" errors when the app tries to fetch place details.
UL_GOOGLE_PLACES_API_KEY=

# Get your Google Maps API Key at https://console.developers.google.com/
UL_GOOGLE_MAPS_API_KEY=

UL_STREET_VIEW_API_KEY=

# Get your Brave Search API Key at https://api.search.brave.com/app/keys
# This is the default search provider. Sign up for a free or paid plan and create a key.
UL_BRAVE_SEARCH_API_KEY=

# Get your Google Custom Search JSON API Key at https://console.developers.google.com/
# NOTE: This is a server-side request. Do not use a browser key restricted by HTTP referrers; Google will reject it with "Requests from referer <empty> are blocked." Use a separate key with no application restriction or an IP restriction that matches the server/container, and restrict the key to the Custom Search JSON API.
UL_GOOGLE_SEARCH_API_KEY=

# Configure your Google Custom Search Engine tenant at https://cse.google.com/cse/all
UL_GOOGLE_SEARCH_TENANT=

# Get your OpenWeatherMap API Key at https://home.openweathermap.org/users/sign_up
UL_OPENWEATHERMAP_API_KEY=

# Get your National Park Service API Key at https://www.nps.gov/subjects/digital/nps-data-api.htm
UL_NPS_API_KEY=

# Configure your Cloudflare AI Endpoint in your Cloudflare dashboard
UL_CLOUDFLARE_AI_ENDPOINT=

# Get your Cloudflare AI API Key at https://dash.cloudflare.com/
UL_CLOUDFLARE_AI_API_KEY=

# Configure your Cloudflare Worker AI Endpoint in your Cloudflare dashboard
UL_CLOUDFLARE_WORKER_AI_ENDPOINT=

# Get your Cloudflare Worker AI API Key at https://dash.cloudflare.com/
UL_CLOUDFLARE_WORKER_AI_API_KEY=

# Configure your Hugging Face AI Endpoint in your Hugging Face settings
UL_HUGGINGFACE_AI_ENDPOINT=

# Get your Hugging Face AI API Key at https://huggingface.co/settings/tokens
UL_HUGGINGFACE_AI_API_KEY=

# Get your OpenAI API Key at https://beta.openai.com/signup/
UL_OPENAI_API_KEY=

# SMTP (e.g. Smtp2Go)
UL_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
UL_EMAIL_HOST=smtp.gmail.com
UL_EMAIL_PORT=587
UL_EMAIL_TLS=True
UL_EMAIL_USE_SSL=False
UL_EMAIL_FROM=noreply@mydomain.org
UL_EMAIL_USER=
UL_EMAIL_PASSWORD=
# Database backups
# Scheduled backups are checked hourly; this controls whether they run.
UL_BACKUP_ENABLED=True
# Minimum hours between scheduled backups. Site admins can override this in the UI.
UL_BACKUP_FREQUENCY_HOURS=24
# Number of backup files to retain. Site admins can override this in the UI.
UL_BACKUP_RETENTION=30
# Optional backup directory override (defaults to the app backups directory).
UL_BACKUPS_DIR=backups
