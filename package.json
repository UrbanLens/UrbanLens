{
    "name": "urbanlens",
    "version": "0.2.0",
    "description": "Mapping for Urban Explorers",
    "main": "index.js",
    "scripts": {
        "db": "python src/bin/db.py start",
        "migrate": "python -m urbanlens.manage makemigrations & python -m urbanlens.manage migrate",
        "sass": "sass --style=compressed --no-source-map src/urbanlens/dashboard/frontend/sass/style.scss src/urbanlens/dashboard/frontend/static/dashboard/style.css",
        "sass:dev": "sass --style=expanded src/urbanlens/dashboard/frontend/sass/style.scss src/urbanlens/dashboard/frontend/static/dashboard/style.css",
        "sass:watch": "sass --watch --style=expanded src/urbanlens/dashboard/frontend/sass/style.scss src/urbanlens/dashboard/frontend/static/dashboard/style.css",
        "build": "bun build src/urbanlens/dashboard/frontend/ts/index.tsx --outdir src/urbanlens/dashboard/frontend/static/dashboard/js --target browser",
        "deploy": "bun build src/urbanlens/dashboard/frontend/ts/index.tsx --outdir src/urbanlens/dashboard/frontend/static/dashboard/js --target browser",
        "start": "gunicorn urbanlens.UrbanLens.wsgi:application --bind 0.0.0.0:8000 -t 600 -k gevent",
        "git-squash": "pkill gunicorn && git fetch origin && git reset --hard origin/main && npm run start",
        "lint": "pyright src/urbanlens",
        "up": "git pull && sudo docker compose build && sudo docker compose up",
        "test": "python -m coverage run --source='src' src/urbanlens/manage.py test",
        "coverage": "python -m coverage report",
        "uninstall": "echo \"docker compose down && docker volume ls -q | grep '^urbanlens_' | xargs -r docker volume rm\""
    },
    "author": "Jess Mann",
    "license": "N/A",
    "devDependencies": {
        "bun-types": "latest"
    },
    "peerDependencies": {
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "bun": "^1.0.15",
        "dotenv": "^10.0.0",
        "dotenv-expand": "^5.1.0",
        "sass": "^1.69.5",
        "sass-loader": "^12.3.0",
        "semver": "^7.3.5",
        "typescript": "^5.0.0",
        "yarn": "^1.22.19"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 2 chrome versions",
            "last 2 firefox versions",
            "last 2 safari versions",
            "last 2 ios versions",
            "last 1 android version",
            "last 1 chromeandroid version",
            "ie 11"
        ]
    }
}